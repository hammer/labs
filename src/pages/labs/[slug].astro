---
import Layout from '../../components/Layout.astro';
import OutputCard from '../../components/OutputCard.astro';
import TagList from '../../components/TagList.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getAllLabs, getLabBySlug, getOutputsForLab, slugifyName } from '../../data/loader.js';
import { isGrouped, getOutputTypes } from '../../schema.js';
import type { FilterDimension } from '../../lib/filters/types.js';

export function getStaticPaths() {
  return getAllLabs().map((lab) => ({ params: { slug: lab.slug } }));
}

const { slug } = Astro.params;
const lab = getLabBySlug(slug!)!;
const outputs = getOutputsForLab(slug!);

const typeCounts = new Map<string, number>();
const tagCounts = new Map<string, number>();

outputs.forEach(o => {
  getOutputTypes(o).forEach(t => typeCounts.set(t, (typeCounts.get(t) || 0) + 1));
  (o.tags || []).forEach(t => tagCounts.set(t, (tagCounts.get(t) || 0) + 1));
});

const types = [...typeCounts.keys()].sort();
const tags = [...tagCounts.keys()].sort();

const dimensions: FilterDimension[] = [
  { key: 'flagship', label: 'Flagship', kind: 'tristate', rowAttr: 'flagship' },
  {
    key: 'type', label: 'Type', kind: 'multi', rowAttr: 'type',
    options: types.map(t => ({ slug: t, label: t, count: typeCounts.get(t) ?? 0 })),
  },
  {
    key: 'tag', label: 'Tag', kind: 'multi', rowAttr: 'tags',
    options: tags.map(t => ({ slug: t, label: t, count: tagCounts.get(t) ?? 0 })),
  },
];
---

<Layout title={lab.name}>
  <header class="page-header">
    <div class="title-row">
      <h1>{lab.name}</h1>
      {lab.type && <TypeBadge type={lab.type} />}
    </div>
    <p class="meta">
      {lab.region}
      {lab.founded && <span> · Founded {lab.founded}</span>}
      {lab.parent && <span> · Part of {lab.parent}</span>}
      {lab.ipo && <span> · IPO {lab.ipo.year} ({lab.ipo.exchange}: {lab.ipo.ticker})</span>}
      {lab.valuation && (
        <span> · {lab.valuation.type === 'market-cap' ? 'Market cap' : lab.valuation.type === 'revenue' ? 'Revenue' : 'Valuation'}: {lab.valuation.amount}
          {lab.valuation.ticker && <span> ({lab.valuation.ticker})</span>}
          <span class="valuation-date"> as of {lab.valuation.date}</span>
        </span>
      )}
    </p>
    {lab.description && <div class="description" set:html={lab.description} />}

    <div class="links">
      {lab.url && <a href={lab.url}>Website</a>}
      {lab.wikipedia && <a href={lab.wikipedia}>Wikipedia</a>}
      {lab.huggingface && <a href={lab.huggingface}>HuggingFace</a>}
      {lab.github && <a href={lab.github}>GitHub</a>}
      {lab.youtube && <a href={lab.youtube}>YouTube</a>}
      {lab.artificialanalysis && <a href={lab.artificialanalysis}>Artificial Analysis</a>}
      {lab.openrouter && <a href={lab.openrouter}>OpenRouter</a>}
    </div>

    {lab.tags && <TagList tags={lab.tags} />}
  </header>

  {lab.people && lab.people.length > 0 && (
    <section class="section">
      <h2>People</h2>
      <ul class="people-list">
        {lab.people.map((p) => (
          <li>
            <strong><a href={`/people/${p.slug || slugifyName(p.name)}`}>{p.name}</a></strong>
            {p.urls && p.urls.map((link) => (
              <a href={link.url} class="person-link">{link.label}</a>
            ))}
            {p.role && <span class="role"> — {p.role}</span>}
            {p.formerly && <span class="formerly"> (formerly {p.formerly})</span>}
          </li>
        ))}
      </ul>
    </section>
  )}

  {lab.news && lab.news.length > 0 && (
    <section class="section">
      <h2>News</h2>
      <ul class="news-list">
        {[...lab.news].sort((a, b) => b.date.localeCompare(a.date)).map((n) => (
          <li>
            <span class="news-date">{n.date}</span>
            <a href={n.url}>{n.title}</a>
            {n.source && <span class="news-source"> — {n.source}</span>}
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="section">
    <h2 class="outputs-heading">Outputs <span class="count" id="output-count">({outputs.length})</span></h2>

    {outputs.length > 0 && (
      <FilterBar mode="inline" dimensions={dimensions} hotkey="f" id="lab-filter-bar" />
    )}

    {outputs.length === 0 ? (
      <p class="empty">No outputs yet.</p>
    ) : (
      <div class="output-list" id="output-list">
        {outputs.map((output) => (
          <div
            class="output-item"
            data-flagship={output.flagship ? '1' : '0'}
            data-type={getOutputTypes(output).join(',')}
            data-tags={(output.tags || []).join(',')}
          >
            <OutputCard output={output} labSlug={slug} />
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>

<script>
  import type { FilterChangeDetail, FilterDimension } from '../../lib/filters/types';
  import { rowMatches } from '../../lib/filters/state';

  const filterBarEl = document.getElementById('lab-filter-bar');
  const items = Array.from(document.querySelectorAll<HTMLElement>('.output-item'));
  const countEl = document.getElementById('output-count');
  if (filterBarEl && items.length > 0 && countEl) {
    const total = items.length;
    const dimensions: FilterDimension[] = JSON.parse(
      document.getElementById('lab-filter-bar-config')!.textContent!,
    ).dimensions;

    filterBarEl.addEventListener('filters:changed', (e) => {
      const state = (e as CustomEvent<FilterChangeDetail>).detail.state;
      let visible = 0;
      items.forEach(item => {
        const ok = rowMatches(item.dataset as Record<string, string | undefined>, state, dimensions);
        item.style.display = ok ? '' : 'none';
        if (ok) visible++;
      });
      countEl.textContent = visible < total ? `(${visible} of ${total})` : `(${total})`;
    });
  }
</script>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .title-row h1 {
    font-size: 1.5rem;
  }

  .meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .description {
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .description p {
    margin-bottom: 0.6rem;
  }

  .description p:last-child {
    margin-bottom: 0;
  }

  .links {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
  }

  .section {
    margin-bottom: 2rem;
  }

  .section h2 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border);
  }

  .count {
    font-weight: 400;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .valuation-date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .people-list {
    list-style: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .people-list li {
    padding: 0.25rem 0;
  }

  .person-link {
    font-size: 0.75rem;
    margin-left: 0.35rem;
    color: var(--text-muted);
  }

  .role,
  .formerly {
    color: var(--text-muted);
  }

  .news-list {
    list-style: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .news-list li {
    padding: 0.25rem 0;
  }

  .news-date {
    color: var(--text-muted);
    margin-right: 0.5rem;
  }

  .news-source {
    color: var(--text-muted);
  }

  .outputs-heading {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .output-list {
    display: grid;
    gap: 0.75rem;
  }

  .empty {
    color: var(--text-muted);
    font-size: 0.875rem;
  }
</style>
