---
import Layout from '../../../components/Layout.astro';
import TypeBadge from '../../../components/TypeBadge.astro';
import TagList from '../../../components/TagList.astro';
import ModelDetails from '../../../components/ModelDetails.astro';
import PaperDetails from '../../../components/PaperDetails.astro';
import EvalDetails from '../../../components/EvalDetails.astro';
import DatasetDetails from '../../../components/DatasetDetails.astro';
import LibraryDetails from '../../../components/LibraryDetails.astro';
import { getAllOutputsChronological, getOutputBySlug, getLabBySlug, isGrouped, getOutputTypes } from '../../../data/loader.js';

export function getStaticPaths() {
  const paths: { params: { lab: string; slug: string } }[] = [];
  for (const o of getAllOutputsChronological()) {
    // Always generate the canonical page (file directory)
    paths.push({ params: { lab: o._labSlug, slug: o.slug } });
    // For multi-lab outputs, also generate pages for each additional lab
    const labs = Array.isArray(o.lab) ? o.lab : [o.lab];
    for (const labSlug of labs) {
      if (labSlug !== o._labSlug) {
        paths.push({ params: { lab: labSlug, slug: o.slug } });
      }
    }
  }
  return paths;
}

const { lab: labSlug, slug } = Astro.params;
const output = getOutputBySlug(labSlug!, slug!)!;
const labs = Array.isArray(output.lab) ? output.lab : [output.lab];
const labObjects = labs.map((s) => getLabBySlug(s)).filter(Boolean);
const grouped = isGrouped(output);
const types = getOutputTypes(output);
---

<Layout title={output.name}>
  <header class="page-header">
    <div class="title-row">
      <h1>{output.name}</h1>
      {types.map(t => <TypeBadge type={t} />)}
    </div>
    <div class="meta">
      <time>{output.date}</time>
      <span class="lab-links">
        {labObjects.map((lab, i) => (
          <>
            {i > 0 && ', '}
            <a href={`/labs/${lab!.slug}`}>{lab!.name}</a>
          </>
        ))}
      </span>
    </div>
  </header>

  {output.description && (
    <section class="section">
      <div class="description" set:html={output.description} />
    </section>
  )}

  <div class="links-row">
    {output.sources.map((source, i) => (
      <a href={source.url} class={i === 0 ? 'primary-link' : ''}>{source.label}</a>
    ))}
  </div>

  {/* Simple output: type-specific detail components */}
  {!grouped && 'model' in output && output.model && (
    <section class="section">
      <h2>Model Details</h2>
      <ModelDetails model={output.model} metrics={output._metrics} />
    </section>
  )}

  {!grouped && 'paper' in output && output.paper && (
    <section class="section">
      <h2>Paper</h2>
      <PaperDetails paper={output.paper} metrics={output._metrics} />
    </section>
  )}

  {!grouped && 'eval' in output && output.eval && (
    <section class="section">
      <h2>Evaluation Details</h2>
      <EvalDetails eval={output.eval} />
    </section>
  )}

  {!grouped && 'library' in output && output.library && (
    <section class="section">
      <h2>Library</h2>
      <LibraryDetails library={output.library} metrics={output._metrics} />
    </section>
  )}

  {!grouped && 'dataset' in output && output.dataset && (
    <section class="section">
      <h2>Dataset</h2>
      <DatasetDetails dataset={output.dataset} metrics={output._metrics} />
    </section>
  )}

  {/* Grouped output: show sub-outputs */}
  {grouped && (
    <section class="sub-outputs">
      <h2>Outputs <span class="sub-count">{output.outputs.length}</span></h2>
      {output.outputs.map((sub, i) => (
        <div class="sub-output" data-index={i}>
          <div class="sub-header">
            <h3>{sub.name}</h3>
            <TypeBadge type={sub.type} />
            {sub.date && sub.date !== output.date && <time class="sub-date">{sub.date}</time>}
          </div>

          {sub.description && <p class="sub-description">{sub.description}</p>}

          {sub.sources && sub.sources.length > 0 && (
            <div class="links-row sub-links">
              {sub.sources.map((s) => (
                <a href={s.url}>{s.label}</a>
              ))}
            </div>
          )}

          {sub.model && <ModelDetails model={sub.model} metrics={output._metrics} />}
          {sub.paper && <PaperDetails paper={sub.paper} metrics={output._metrics} />}
          {sub.eval && <EvalDetails eval={sub.eval} />}
          {sub.library && <LibraryDetails library={sub.library} metrics={output._metrics} />}
          {sub.dataset && <DatasetDetails dataset={sub.dataset} metrics={output._metrics} />}

          {sub.notes && <p class="sub-notes">{sub.notes}</p>}
        </div>
      ))}
    </section>
  )}

  {output.tags && <TagList tags={output.tags} />}

  {output.links && output.links.length > 0 && (
    <section class="section">
      <h2>More Links</h2>
      <ul class="more-links-list">
        {output.links.map((link) => (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {output.related && output.related.length > 0 && (
    <section class="section">
      <h2>Related</h2>
      <ul class="related-list">
        {output.related.map((r) => (
          <li>{r}</li>
        ))}
      </ul>
    </section>
  )}

  {output.notes && (
    <section class="section notes">
      <h2>Notes</h2>
      <p>{output.notes}</p>
    </section>
  )}
</Layout>

<script>
  const subs = Array.from(document.querySelectorAll<HTMLElement>('.sub-output'));
  if (subs.length > 0) {
    let selected = -1;

    function selectSub(index: number) {
      const clamped = Math.max(0, Math.min(index, subs.length - 1));
      subs.forEach(s => s.classList.remove('sub-selected'));
      selected = clamped;
      subs[selected].classList.add('sub-selected');
      subs[selected].scrollIntoView({ block: 'nearest' });
    }

    document.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      if (e.ctrlKey || e.metaKey || e.altKey) return;

      if (e.key === 'j') {
        e.preventDefault();
        selectSub(selected + 1);
      } else if (e.key === 'k') {
        e.preventDefault();
        selectSub(selected - 1);
      } else if (e.key === 'Escape') {
        subs.forEach(s => s.classList.remove('sub-selected'));
        selected = -1;
      }
    });
  }
</script>

<style>
  .page-header {
    margin-bottom: 1.5rem;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .title-row h1 {
    font-size: 1.5rem;
  }

  .meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.75rem;
  }

  .description {
    font-size: 0.925rem;
    line-height: 1.7;
  }

  .links-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
  }

  .primary-link {
    font-weight: 600;
  }

  .section {
    margin-bottom: 1.5rem;
  }

  .section h2 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border);
  }

  .paper-details p {
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
  }

  .more-links-list,
  .related-list {
    font-size: 0.875rem;
    padding-left: 1.25rem;
  }

  .notes p {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Sub-outputs */
  .sub-outputs h2 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border);
  }

  .sub-count {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  .sub-output {
    padding: 0.75rem 1rem;
    margin-bottom: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    transition: outline 0.08s;
  }

  .sub-output.sub-selected {
    outline: 2px solid rgba(37, 99, 235, 0.4);
    outline-offset: -1px;
    background: rgba(37, 99, 235, 0.04);
  }

  .sub-header {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.4rem;
  }

  .sub-header h3 {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .sub-date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .sub-description {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }

  .sub-links {
    margin-bottom: 0.5rem;
  }

  .sub-notes {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 0.4rem;
  }
</style>
