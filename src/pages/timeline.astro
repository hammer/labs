---
import Layout from '../components/Layout.astro';
import TypeBadge from '../components/TypeBadge.astro';
import { getAllOutputsChronological, getAllLabs, getLabBySlug, isGrouped, getOutputTypes } from '../data/loader.js';

const outputs = getAllOutputsChronological();
const labs = getAllLabs().map((l) => ({ slug: l.slug, name: l.name })).sort((a, b) => a.name.localeCompare(b.name));
const allTypes = outputs.flatMap(o => getOutputTypes(o));
const types = [...new Set(allTypes)].sort();
---

<Layout title="Timeline">
  <header class="page-header">
    <h1>Timeline</h1>
    <p class="subtitle">{outputs.length} outputs &middot; <button class="shortcut-hint" id="shortcut-hint">Keyboard shortcuts <kbd>?</kbd></button></p>
  </header>

  <div class="filter-bar">
    <select id="filter-lab">
      <option value="">All labs</option>
      {labs.map((l) => (
        <option value={l.slug}>{l.name}</option>
      ))}
    </select>
    <select id="filter-type">
      <option value="">All types</option>
      {types.map((t) => (
        <option value={t}>{t}</option>
      ))}
    </select>
    <span class="filter-count" id="filter-count"></span>
  </div>

  <table class="timeline-table" id="timeline-table">
    <thead>
      <tr>
        <th class="col-date">Date</th>
        <th class="col-name">Name</th>
        <th class="col-lab">Lab</th>
        <th class="col-type">Type</th>
      </tr>
    </thead>
    <tbody>
      {outputs.map((output, i) => {
        const labList = Array.isArray(output.lab) ? output.lab : [output.lab];
        const labNames = labList.map(s => getLabBySlug(s)?.name ?? s).join(', ');
        const outputTypes = getOutputTypes(output);
        const grouped = isGrouped(output);
        return (
          <tr
            class="tl-row"
            data-href={`/outputs/${output._labSlug}/${output.slug}`}
            data-lab={labList.join(',')}
            data-type={outputTypes.join(',')}
            data-index={i}
          >
            <td class="col-date">{output.date}</td>
            <td class="col-name">
              {output.name}
              {grouped && <span class="group-badge">{output.outputs.length}</span>}
            </td>
            <td class="col-lab">{labNames}</td>
            <td class="col-type">
              {outputTypes.map(t => <TypeBadge type={t} />)}
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>

  <div class="shortcut-modal hidden" id="shortcut-modal">
    <div class="shortcut-backdrop" id="shortcut-backdrop"></div>
    <div class="shortcut-dialog">
      <h3>Keyboard shortcuts</h3>
      <div class="shortcut-grid">
        <div class="shortcut-group">
          <h4>Navigation</h4>
          <dl>
            <div><dt><kbd>j</kbd></dt><dd>Move down</dd></div>
            <div><dt><kbd>k</kbd></dt><dd>Move up</dd></div>
            <div><dt><kbd>o</kbd> / <kbd>Enter</kbd></dt><dd>Open output</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>g</kbd></dt><dd>Go to top</dd></div>
            <div><dt><kbd>G</kbd></dt><dd>Go to bottom</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>h</kbd></dt><dd>Go home</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>t</kbd></dt><dd>Go to timeline</dd></div>
          </dl>
        </div>
        <div class="shortcut-group">
          <h4>Other</h4>
          <dl>
            <div><dt><kbd>/</kbd></dt><dd>Search</dd></div>
            <div><dt><kbd>Esc</kbd></dt><dd>Clear / close</dd></div>
            <div><dt><kbd>?</kbd></dt><dd>Show this help</dd></div>
          </dl>
        </div>
      </div>
      <button class="close-btn" id="close-shortcuts">&times;</button>
    </div>
  </div>

  <div class="search-bar" id="search-bar">
    <input type="text" id="search-input" placeholder="Search outputs..." autocomplete="off" />
  </div>
</Layout>

<script>
  const allRows = Array.from(document.querySelectorAll<HTMLTableRowElement>('.tl-row'));
  const modal = document.getElementById('shortcut-modal')!;
  const backdrop = document.getElementById('shortcut-backdrop')!;
  const closeBtn = document.getElementById('close-shortcuts')!;
  const hintBtn = document.getElementById('shortcut-hint')!;
  const searchBar = document.getElementById('search-bar')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const labSelect = document.getElementById('filter-lab') as HTMLSelectElement;
  const typeSelect = document.getElementById('filter-type') as HTMLSelectElement;
  const filterCount = document.getElementById('filter-count')!;

  let selected = -1;
  let visibleRows: HTMLTableRowElement[] = [...allRows];
  let waitingForG = false;
  let gTimer: ReturnType<typeof setTimeout> | null = null;
  let searchQuery = '';

  function updateVisibility() {
    const lab = labSelect.value;
    const type = typeSelect.value;
    const q = searchQuery.toLowerCase();

    allRows.forEach(row => {
      const labs = row.dataset.lab!.split(',');
      const rowTypes = row.dataset.type!.split(',');
      const name = row.querySelector('.col-name')?.textContent?.toLowerCase() ?? '';
      const labName = row.querySelector('.col-lab')?.textContent?.toLowerCase() ?? '';

      const matchLab = !lab || labs.includes(lab);
      const matchType = !type || rowTypes.includes(type);
      const matchSearch = !q || name.includes(q) || labName.includes(q);

      row.style.display = (matchLab && matchType && matchSearch) ? '' : 'none';
    });

    visibleRows = allRows.filter(r => r.style.display !== 'none');
    filterCount.textContent = visibleRows.length < allRows.length
      ? `${visibleRows.length} of ${allRows.length}`
      : '';

    if (selected >= visibleRows.length) {
      select(visibleRows.length - 1);
    }
  }

  function select(index: number) {
    if (visibleRows.length === 0) return;
    const clamped = Math.max(0, Math.min(index, visibleRows.length - 1));
    allRows.forEach(r => r.classList.remove('selected'));
    selected = clamped;
    visibleRows[selected].classList.add('selected');
    visibleRows[selected].scrollIntoView({ block: 'nearest' });
  }

  function openSelected() {
    if (selected >= 0 && selected < visibleRows.length) {
      const href = visibleRows[selected].dataset.href;
      if (href) window.location.href = href;
    }
  }

  function toggleModal(show?: boolean) {
    const isShown = !modal.classList.contains('hidden');
    modal.classList.toggle('hidden', show !== undefined ? !show : isShown);
  }

  function toggleSearch(show?: boolean) {
    const isShown = searchBar.classList.contains('active');
    const shouldShow = show ?? !isShown;
    searchBar.classList.toggle('active', shouldShow);
    if (shouldShow) {
      searchInput.focus();
    } else {
      searchInput.value = '';
      searchQuery = '';
      updateVisibility();
      searchInput.blur();
    }
  }

  // Click to navigate
  allRows.forEach(row => {
    row.addEventListener('click', () => {
      const href = row.dataset.href;
      if (href) window.location.href = href;
    });
  });

  // Filters
  labSelect.addEventListener('change', updateVisibility);
  typeSelect.addEventListener('change', updateVisibility);

  searchInput.addEventListener('input', () => {
    searchQuery = searchInput.value;
    updateVisibility();
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) {
      if (e.key === 'Escape') {
        toggleSearch(false);
        e.preventDefault();
      } else if (e.key === 'Enter') {
        openSelected();
        e.preventDefault();
      }
      return;
    }
    if (e.target instanceof HTMLSelectElement) return;
    if (e.ctrlKey || e.metaKey || e.altKey) return;

    switch (e.key) {
      case 'j':
        e.preventDefault();
        select(selected + 1);
        break;
      case 'k':
        e.preventDefault();
        select(selected - 1);
        break;
      case 'o':
      case 'Enter':
        e.preventDefault();
        openSelected();
        break;
      case 'g':
        if (waitingForG) {
          e.preventDefault();
          select(0);
          waitingForG = false;
          if (gTimer) clearTimeout(gTimer);
        } else {
          waitingForG = true;
          gTimer = setTimeout(() => { waitingForG = false; }, 500);
        }
        break;
      case 'G':
        e.preventDefault();
        select(visibleRows.length - 1);
        break;
      case '?':
        e.preventDefault();
        toggleModal();
        break;
      case '/':
        e.preventDefault();
        toggleSearch(true);
        break;
      case 'Escape':
        e.preventDefault();
        if (!modal.classList.contains('hidden')) {
          toggleModal(false);
        } else if (searchBar.classList.contains('active')) {
          toggleSearch(false);
        } else {
          allRows.forEach(r => r.classList.remove('selected'));
          selected = -1;
        }
        break;
    }
  });

  backdrop.addEventListener('click', () => toggleModal(false));
  closeBtn.addEventListener('click', () => toggleModal(false));
  hintBtn.addEventListener('click', () => toggleModal(true));
</script>

<style>
  .page-header {
    margin-bottom: 1.25rem;
  }

  .page-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .shortcut-hint {
    all: unset;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .shortcut-hint:hover {
    color: var(--text);
  }

  .shortcut-hint kbd {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0 0.3em;
    font-size: 0.75rem;
    font-family: inherit;
    margin-left: 0.15em;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .filter-bar select {
    padding: 0.375rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.85rem;
    background: var(--surface);
    color: var(--text);
  }

  .filter-count {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Table */
  .timeline-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .timeline-table thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .timeline-table th {
    text-align: left;
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    background: var(--bg);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
    user-select: none;
  }

  .tl-row {
    cursor: pointer;
    transition: background 0.08s;
  }

  .tl-row td {
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .tl-row:hover {
    background: rgba(37, 99, 235, 0.04);
  }

  .tl-row.selected {
    background: rgba(37, 99, 235, 0.08);
    outline: 2px solid rgba(37, 99, 235, 0.3);
    outline-offset: -2px;
  }

  .tl-row:last-child td {
    border-bottom: none;
  }

  /* Columns */
  .col-date {
    white-space: nowrap;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    width: 7rem;
  }

  td.col-name {
    font-weight: 600;
  }

  .col-lab {
    white-space: nowrap;
    color: var(--text-muted);
  }

  .col-type {
    white-space: nowrap;
    display: flex;
    gap: 0.3rem;
  }

  .group-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 600;
    min-width: 1.2em;
    padding: 0 0.35em;
    height: 1.2em;
    border-radius: 9999px;
    background: var(--border);
    color: var(--text-muted);
    margin-left: 0.35rem;
    vertical-align: middle;
  }

  /* Search bar */
  .search-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: none;
    justify-content: center;
    padding: 1rem;
    background: rgba(0,0,0,0.15);
  }

  .search-bar.active {
    display: flex;
  }

  .search-bar input {
    width: 100%;
    max-width: 480px;
    padding: 0.6rem 1rem;
    font-size: 1rem;
    border: 2px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text);
    outline: none;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  }

  .search-bar input:focus {
    border-color: #2563eb;
  }

  /* Shortcuts modal */
  .shortcut-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shortcut-modal.hidden {
    display: none;
  }

  .shortcut-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
  }

  .shortcut-dialog {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem 2rem;
    max-width: 480px;
    width: 90%;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .shortcut-dialog h3 {
    font-size: 1.125rem;
    margin-bottom: 1.25rem;
  }

  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .shortcut-group h4 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .shortcut-group dl {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .shortcut-group dl > div {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .shortcut-group dt {
    flex-shrink: 0;
  }

  .shortcut-group dd {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: right;
  }

  .shortcut-group kbd {
    display: inline-block;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15em 0.45em;
    font-size: 0.8rem;
    font-family: inherit;
    min-width: 1.6em;
    text-align: center;
    box-shadow: 0 1px 0 var(--border);
  }

  .close-btn {
    all: unset;
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-size: 1.25rem;
    cursor: pointer;
    color: var(--text-muted);
    line-height: 1;
  }

  .close-btn:hover {
    color: var(--text);
  }
</style>
