---
import Layout from '../components/Layout.astro';
import TypeBadge from '../components/TypeBadge.astro';
import FilterBar from '../components/FilterBar.astro';
import { getAllTimelineItems, getAllLabs, getLabBySlug, isGrouped, getOutputTypes } from '../data/loader.js';
import type { NewsItem } from '../data/loader.js';
import { formatCompact } from '../utils.js';
import type { FilterDimension } from '../lib/filters/types.js';

const items = getAllTimelineItems();
const outputCount = items.filter(i => i._kind === 'output').length;
const newsCount = items.filter(i => i._kind === 'news').length;
const labs = getAllLabs().map((l) => ({ slug: l.slug, name: l.name })).sort((a, b) => a.name.localeCompare(b.name));

const labCounts = new Map<string, number>();
const typeCounts = new Map<string, number>();
const tagCounts = new Map<string, number>();

items.forEach(item => {
  if (item._kind === 'output') {
    const labList = Array.isArray(item.lab) ? item.lab : [item.lab];
    labList.forEach(l => labCounts.set(l, (labCounts.get(l) || 0) + 1));
    getOutputTypes(item).forEach(t => typeCounts.set(t, (typeCounts.get(t) || 0) + 1));
    (item.tags || []).forEach(t => tagCounts.set(t, (tagCounts.get(t) || 0) + 1));
  } else {
    labCounts.set(item._labSlug, (labCounts.get(item._labSlug) || 0) + 1);
  }
});
typeCounts.set('news', newsCount);

const types = [...typeCounts.keys()].sort();
const tags = [...tagCounts.keys()].sort();

const dimensions: FilterDimension[] = [
  {
    key: 'flagship',
    label: 'Flagship',
    kind: 'tristate',
    rowAttr: 'flagship',
  },
  {
    key: 'type',
    label: 'Type',
    kind: 'multi',
    rowAttr: 'type',
    options: types.map(t => ({ slug: t, label: t, count: typeCounts.get(t) ?? 0 })),
  },
  {
    key: 'lab',
    label: 'Lab',
    kind: 'multi',
    rowAttr: 'lab',
    options: labs.map(l => ({ slug: l.slug, label: l.name, count: labCounts.get(l.slug) ?? 0 })),
  },
  {
    key: 'tag',
    label: 'Tag',
    kind: 'multi',
    rowAttr: 'tags',
    options: tags.map(t => ({ slug: t, label: t, count: tagCounts.get(t) ?? 0 })),
  },
];
---

<Layout title="Timeline">
  <header class="page-header">
    <h1>Timeline</h1>
    <p class="subtitle">{outputCount} outputs, {newsCount} news &middot; <button class="shortcut-hint" id="shortcut-hint">Keyboard shortcuts <kbd>?</kbd></button></p>
  </header>

  <div class="view-bar">
    <div class="view-toggle" id="view-toggle">
      <button class="view-btn active" data-view="all">All</button>
      <button class="view-btn" data-view="outputs">Outputs</button>
      <button class="view-btn" data-view="news">News</button>
    </div>
  </div>

  <FilterBar mode="inline" dimensions={dimensions} hotkey="f" id="filter-bar" />

  <table class="timeline-table" id="timeline-table">
    <thead>
      <tr>
        <th class="col-date sortable" data-sort="date">Date <span class="sort-arrow active-desc">&#9662;</span></th>
        <th class="col-name">Name</th>
        <th class="col-lab">Lab</th>
        <th class="col-type">Type</th>
        <th class="col-metric sortable" data-sort="stars" title="GitHub stars — max across all repos referenced in the output">Stars <span class="sort-arrow"></span></th>
        <th class="col-metric sortable" data-sort="downloads" title="HuggingFace downloads — summed across all unique models in the output">Downloads <span class="sort-arrow"></span></th>
        <th class="col-metric sortable" data-sort="citations" title="OpenAlex citations — summed across all unique papers in the output">Citations <span class="sort-arrow"></span></th>
      </tr>
    </thead>
    <tbody>
      {items.map((item, i) => {
        if (item._kind === 'news') {
          const news = item as NewsItem;
          return (
            <tr
              class="tl-row tl-news"
              data-href={news.url}
              data-external="1"
              data-lab={news._labSlug}
              data-type="news"
              data-tags=""
              data-flagship="0"
              data-date={news.date}
              data-stars=""
              data-downloads=""
              data-citations=""
              data-kind="news"
              data-index={i}
            >
              <td class="col-date">{news.date}</td>
              <td class="col-name">
                <a href={news.url} class="news-link" target="_blank" rel="noopener">{news.title}</a>
                {news.source && <span class="news-source">{news.source}</span>}
              </td>
              <td class="col-lab"><a href={`/labs/${news._labSlug}`} class="lab-link">{news.labName}</a></td>
              <td class="col-type"><TypeBadge type="news" /></td>
              <td class="col-metric"><span class="no-data">&mdash;</span></td>
              <td class="col-metric"><span class="no-data">&mdash;</span></td>
              <td class="col-metric"><span class="no-data">&mdash;</span></td>
            </tr>
          );
        }

        const labList = Array.isArray(item.lab) ? item.lab : [item.lab];
        const labEntries = labList.map(s => ({ slug: s, name: getLabBySlug(s)?.name ?? s }));
        const outputTypes = getOutputTypes(item);
        const grouped = isGrouped(item);
        const m = item._metrics;
        return (
          <tr
            class="tl-row"
            data-href={`/outputs/${item._labSlug}/${item.slug}`}
            data-lab={labList.join(',')}
            data-type={outputTypes.join(',')}
            data-tags={(item.tags || []).join(',')}
            data-flagship={item.flagship ? '1' : '0'}
            data-date={item.date}
            data-stars={m?.github_stars ?? ''}
            data-downloads={m?.hf_downloads ?? ''}
            data-citations={m?.citations ?? ''}
            data-kind="output"
            data-index={i}
          >
            <td class="col-date">{item.date}</td>
            <td class="col-name">
              {item.flagship && <span class="flagship-star" title="Flagship release">&#9733;</span>}
              {item.name}
              {grouped && <span class="group-badge">{item.outputs.length}</span>}
            </td>
            <td class="col-lab">{labEntries.map((l, j) => <>{j > 0 && ', '}<a href={`/labs/${l.slug}`} class="lab-link">{l.name}</a></>)}</td>
            <td class="col-type">
              {outputTypes.map(t => <TypeBadge type={t} />)}
            </td>
            <td class="col-metric">{m?.github_stars ? formatCompact(m.github_stars) : <span class="no-data">&mdash;</span>}</td>
            <td class="col-metric">{m?.hf_downloads ? formatCompact(m.hf_downloads) : <span class="no-data">&mdash;</span>}</td>
            <td class="col-metric">{m?.citations ? formatCompact(m.citations) : <span class="no-data">&mdash;</span>}</td>
          </tr>
        );
      })}
    </tbody>
  </table>

  <div class="shortcut-modal hidden" id="shortcut-modal">
    <div class="shortcut-backdrop" id="shortcut-backdrop"></div>
    <div class="shortcut-dialog">
      <h3>Keyboard shortcuts</h3>
      <div class="shortcut-grid">
        <div class="shortcut-group">
          <h4>Navigation</h4>
          <dl>
            <div><dt><kbd>j</kbd></dt><dd>Move down</dd></div>
            <div><dt><kbd>k</kbd></dt><dd>Move up</dd></div>
            <div><dt><kbd>o</kbd> / <kbd>Enter</kbd></dt><dd>Open item</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>g</kbd></dt><dd>Go to top</dd></div>
            <div><dt><kbd>G</kbd></dt><dd>Go to bottom</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>h</kbd></dt><dd>Go home</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>t</kbd></dt><dd>Go to timeline</dd></div>
          </dl>
        </div>
        <div class="shortcut-group">
          <h4>Other</h4>
          <dl>
            <div><dt><kbd>/</kbd></dt><dd>Search</dd></div>
            <div><dt><kbd>f</kbd></dt><dd>Open filters</dd></div>
            <div><dt><kbd>v</kbd></dt><dd>Cycle view</dd></div>
            <div><dt><kbd>s</kbd></dt><dd>Cycle sort</dd></div>
            <div><dt><kbd>Esc</kbd></dt><dd>Clear / close</dd></div>
            <div><dt><kbd>?</kbd></dt><dd>Show this help</dd></div>
          </dl>
        </div>
      </div>
      <button class="close-btn" id="close-shortcuts">&times;</button>
    </div>
  </div>
</Layout>

<script>
  import type { FilterChangeDetail } from '../lib/filters/types';
  import { rowMatches } from '../lib/filters/state';
  import type { FilterDimension } from '../lib/filters/types';

  const tbody = document.querySelector<HTMLTableSectionElement>('#timeline-table tbody')!;
  const allRows = Array.from(document.querySelectorAll<HTMLTableRowElement>('.tl-row'));
  const modal = document.getElementById('shortcut-modal')!;
  const backdrop = document.getElementById('shortcut-backdrop')!;
  const closeBtn = document.getElementById('close-shortcuts')!;
  const hintBtn = document.getElementById('shortcut-hint')!;
  const sortHeaders = document.querySelectorAll<HTMLTableCellElement>('.sortable');
  const viewBtns = document.querySelectorAll<HTMLButtonElement>('.view-btn');
  const filterBarEl = document.getElementById('filter-bar')!;
  const filterCountEl = filterBarEl.querySelector<HTMLElement>('.filter-count')!;

  // Read dim config from the script tag the FilterBar component injected.
  const dimensions: FilterDimension[] = JSON.parse(
    document.getElementById('filter-bar-config')!.textContent!,
  ).dimensions;

  let selected = -1;
  let visibleRows: HTMLTableRowElement[] = [...allRows];
  let waitingForG = false;
  let gTimer: ReturnType<typeof setTimeout> | null = null;
  let currentView: 'all' | 'outputs' | 'news' = 'all';
  let lastFilterState: Parameters<typeof rowMatches>[1] = {};

  // Sort state
  type SortColumn = 'date' | 'stars' | 'downloads' | 'citations';
  let currentSort: SortColumn = 'date';
  let sortDesc = true;
  const sortCycle: SortColumn[] = ['date', 'stars', 'downloads', 'citations'];

  // ─── View toggle ─────────────────────────────────────────────────────

  viewBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentView = btn.dataset.view as typeof currentView;
      viewBtns.forEach(b => b.classList.toggle('active', b === btn));
      updateVisibility();
      syncViewToURL();
    });
  });

  function cycleView() {
    const views: typeof currentView[] = ['all', 'outputs', 'news'];
    const idx = views.indexOf(currentView);
    const next = views[(idx + 1) % views.length];
    const btn = document.querySelector<HTMLButtonElement>(`.view-btn[data-view="${next}"]`);
    if (btn) btn.click();
  }

  // ─── Filter integration ──────────────────────────────────────────────

  filterBarEl.addEventListener('filters:changed', (e) => {
    const detail = (e as CustomEvent<FilterChangeDetail>).detail;
    lastFilterState = detail.state;
    updateVisibility();
  });

  // ─── Sort ────────────────────────────────────────────────────────────

  function getNumericAttr(row: HTMLTableRowElement, attr: string): number {
    const v = row.dataset[attr];
    return v ? Number(v) : -1;
  }

  function sortRows(column: SortColumn, desc: boolean) {
    currentSort = column;
    sortDesc = desc;

    allRows.sort((a, b) => {
      let va: number | string, vb: number | string;
      if (column === 'date') {
        va = a.dataset.date!;
        vb = b.dataset.date!;
        return desc ? vb.localeCompare(va as string) : (va as string).localeCompare(vb as string);
      } else {
        va = getNumericAttr(a, column);
        vb = getNumericAttr(b, column);
        if (va === -1 && vb === -1) return 0;
        if (va === -1) return 1;
        if (vb === -1) return -1;
        return desc ? (vb as number) - (va as number) : (va as number) - (vb as number);
      }
    });

    for (const row of allRows) {
      tbody.appendChild(row);
    }

    sortHeaders.forEach(th => {
      const arrow = th.querySelector('.sort-arrow')!;
      const col = th.dataset.sort;
      arrow.className = 'sort-arrow';
      if (col === column) {
        arrow.classList.add(desc ? 'active-desc' : 'active-asc');
        arrow.innerHTML = desc ? '&#9662;' : '&#9652;';
      } else {
        arrow.textContent = '';
      }
    });

    updateVisibility();
    syncViewToURL();
  }

  sortHeaders.forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.sort as SortColumn;
      if (col === currentSort) {
        sortRows(col, !sortDesc);
      } else {
        sortRows(col, true);
      }
    });
  });

  function cycleSortShortcut() {
    const idx = sortCycle.indexOf(currentSort);
    const next = sortCycle[(idx + 1) % sortCycle.length];
    sortRows(next, true);
  }

  // ─── Visibility ──────────────────────────────────────────────────────

  function updateVisibility() {
    allRows.forEach(row => {
      const kind = row.dataset.kind;
      // View filter
      if (currentView === 'outputs' && kind !== 'output') { row.style.display = 'none'; return; }
      if (currentView === 'news' && kind !== 'news') { row.style.display = 'none'; return; }

      // FilterBar state
      const ok = rowMatches(row.dataset as Record<string, string | undefined>, lastFilterState, dimensions);
      row.style.display = ok ? '' : 'none';
    });

    visibleRows = allRows.filter(r => r.style.display !== 'none');
    filterCountEl.textContent = visibleRows.length < allRows.length
      ? `${visibleRows.length} of ${allRows.length}`
      : '';

    if (selected >= visibleRows.length) {
      select(visibleRows.length - 1);
    }
  }

  // ─── Selection ───────────────────────────────────────────────────────

  function select(index: number) {
    if (visibleRows.length === 0) return;
    const clamped = Math.max(0, Math.min(index, visibleRows.length - 1));
    allRows.forEach(r => r.classList.remove('selected'));
    selected = clamped;
    visibleRows[selected]!.classList.add('selected');
    visibleRows[selected]!.scrollIntoView({ block: 'nearest' });
  }

  function openSelected() {
    if (selected >= 0 && selected < visibleRows.length) {
      const row = visibleRows[selected]!;
      const href = row.dataset.href;
      if (!href) return;
      if (row.dataset.external === '1') {
        window.open(href, '_blank', 'noopener');
      } else {
        window.location.href = href;
      }
    }
  }

  function toggleModal(show?: boolean) {
    const isShown = !modal.classList.contains('hidden');
    modal.classList.toggle('hidden', show !== undefined ? !show : isShown);
  }

  // Click to navigate
  allRows.forEach(row => {
    row.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.lab-link')) return;
      if ((e.target as HTMLElement).closest('.news-link')) return;
      const href = row.dataset.href;
      if (!href) return;
      if (row.dataset.external === '1') {
        window.open(href, '_blank', 'noopener');
      } else {
        window.location.href = href;
      }
    });
  });

  // ─── URL sync (view + sort only — filters owned by FilterBar) ────────

  function syncViewToURL() {
    const params = new URLSearchParams(window.location.search);
    if (currentView !== 'all') params.set('view', currentView);
    else params.delete('view');
    if (currentSort !== 'date') params.set('sort', currentSort);
    else params.delete('sort');
    if (!sortDesc) params.set('asc', '1');
    else params.delete('asc');
    const qs = params.toString();
    history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
  }

  function restoreFromURL() {
    const params = new URLSearchParams(window.location.search);
    const view = params.get('view');
    if (view === 'outputs' || view === 'news') {
      currentView = view;
      viewBtns.forEach(b => b.classList.toggle('active', b.dataset.view === view));
    }
    const sort = params.get('sort') as SortColumn | null;
    if (sort && sortCycle.includes(sort)) {
      sortRows(sort, params.get('asc') !== '1');
    }
  }

  restoreFromURL();

  // ─── Keyboard shortcuts ──────────────────────────────────────────────

  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.target instanceof HTMLSelectElement) return;
    if ((window as any).isSearchOpen) return;
    if (e.ctrlKey || e.metaKey || e.altKey) return;

    // FilterBar handles its own keys when its panel is open; let it run.
    const target = e.target as HTMLElement | null;
    if (target?.closest('.dim-panel') || target?.closest('.palette-panel')) return;

    switch (e.key) {
      case 'j':
        e.preventDefault();
        select(selected + 1);
        break;
      case 'k':
        e.preventDefault();
        select(selected - 1);
        break;
      case 'o':
      case 'Enter':
        e.preventDefault();
        openSelected();
        break;
      case 'g':
        if (waitingForG) {
          e.preventDefault();
          select(0);
          waitingForG = false;
          if (gTimer) clearTimeout(gTimer);
        } else {
          waitingForG = true;
          gTimer = setTimeout(() => { waitingForG = false; }, 500);
        }
        break;
      case 'G':
        e.preventDefault();
        select(visibleRows.length - 1);
        break;
      case 'v':
        e.preventDefault();
        cycleView();
        break;
      case 's':
        e.preventDefault();
        cycleSortShortcut();
        break;
      case '?':
        e.preventDefault();
        toggleModal();
        break;
      case 'Escape':
        if (!modal.classList.contains('hidden')) {
          e.preventDefault();
          toggleModal(false);
        } else {
          // FilterBar's own panel-close is handled by its keyboard handler;
          // here we only clear row selection.
          allRows.forEach(r => r.classList.remove('selected'));
          selected = -1;
        }
        break;
    }
  });

  backdrop.addEventListener('click', () => toggleModal(false));
  closeBtn.addEventListener('click', () => toggleModal(false));
  hintBtn.addEventListener('click', () => toggleModal(true));
</script>

<style>
  .page-header {
    margin-bottom: 1.25rem;
  }

  .page-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .shortcut-hint {
    all: unset;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .shortcut-hint:hover {
    color: var(--text);
  }

  .shortcut-hint kbd {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0 0.3em;
    font-size: 0.75rem;
    font-family: inherit;
    margin-left: 0.15em;
  }

  /* View toggle (sibling of FilterBar, owns its own row) */
  .view-bar {
    margin-bottom: 0.6rem;
  }
  .view-toggle {
    display: inline-flex;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .view-btn {
    padding: 0.375rem 0.75rem;
    border: none;
    background: var(--surface);
    color: var(--text-muted);
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .view-btn:not(:last-child) {
    border-right: 1px solid var(--border);
  }
  .view-btn:hover {
    color: var(--text);
  }
  .view-btn.active {
    background: #2563eb;
    color: #fff;
  }

  /* Table */
  .timeline-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .timeline-table thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .timeline-table th {
    text-align: left;
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    background: var(--bg);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
    user-select: none;
  }

  th.sortable {
    cursor: pointer;
  }

  th.sortable:hover {
    color: var(--text);
  }

  .sort-arrow {
    font-size: 0.65rem;
    margin-left: 0.2em;
    color: var(--text-muted);
    opacity: 0;
  }

  .sort-arrow.active-desc,
  .sort-arrow.active-asc {
    opacity: 1;
    color: #2563eb;
  }

  .tl-row {
    cursor: pointer;
    transition: background 0.08s;
  }

  .tl-row td {
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .tl-row:hover {
    background: rgba(37, 99, 235, 0.04);
  }

  .tl-row.selected {
    background: rgba(37, 99, 235, 0.08);
    outline: 2px solid rgba(37, 99, 235, 0.3);
    outline-offset: -2px;
  }

  .tl-row:last-child td {
    border-bottom: none;
  }

  /* News rows */
  .tl-news {
    background: color-mix(in srgb, var(--color-news) 3%, transparent);
  }

  .tl-news:hover {
    background: color-mix(in srgb, var(--color-news) 7%, transparent);
  }

  .tl-news.selected {
    background: color-mix(in srgb, var(--color-news) 12%, transparent);
    outline-color: var(--color-news);
  }

  .news-link {
    color: var(--text);
    font-weight: 600;
  }

  .news-link:hover {
    color: var(--color-news);
  }

  .news-source {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  /* Columns */
  .col-date {
    white-space: nowrap;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    width: 7rem;
  }

  td.col-name {
    font-weight: 600;
  }

  .col-lab {
    white-space: nowrap;
    color: var(--text-muted);
  }

  .lab-link {
    color: var(--text-muted);
  }

  .lab-link:hover {
    color: var(--text);
  }

  td.col-type {
    white-space: nowrap;
  }

  td.col-type > :global(*) {
    margin-right: 0.3rem;
  }

  td.col-type > :global(*:last-child) {
    margin-right: 0;
  }

  th.col-metric {
    text-align: right;
  }

  td.col-metric {
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--text-muted);
    white-space: nowrap;
    font-size: 0.8rem;
  }

  .no-data {
    opacity: 0.3;
  }

  .flagship-star {
    color: #f59e0b;
    font-size: 0.75rem;
    margin-right: 0.25rem;
  }

  .group-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 600;
    min-width: 1.2em;
    padding: 0 0.35em;
    height: 1.2em;
    border-radius: 9999px;
    background: var(--border);
    color: var(--text-muted);
    margin-left: 0.35rem;
    vertical-align: middle;
  }

  /* Hide metric columns on narrow screens */
  @media (max-width: 768px) {
    th.col-metric,
    td.col-metric {
      display: none;
