---
import Layout from '../components/Layout.astro';
import TypeBadge from '../components/TypeBadge.astro';
import FilterBar from '../components/FilterBar.astro';
import { getAllLabs, getOutputCount, getAllOutputsChronological, getLargestModel, getTopIntelligence } from '../data/loader.js';
import type { FilterDimension } from '../lib/filters/types.js';

const labs = getAllLabs().sort((a, b) => getOutputCount(b.slug) - getOutputCount(a.slug));
const totalOutputs = getAllOutputsChronological().length;

const regionFlags: Record<string, string> = {
  china: '\u{1F1E8}\u{1F1F3}',
  korea: '\u{1F1F0}\u{1F1F7}',
  japan: '\u{1F1EF}\u{1F1F5}',
  usa: '\u{1F1FA}\u{1F1F8}',
  uk: '\u{1F1EC}\u{1F1E7}',
  france: '\u{1F1EB}\u{1F1F7}',
  india: '\u{1F1EE}\u{1F1F3}',
  canada: '\u{1F1E8}\u{1F1E6}',
  singapore: '\u{1F1F8}\u{1F1EC}',
  uae: '\u{1F1E6}\u{1F1EA}',
  switzerland: '\u{1F1E8}\u{1F1ED}',
  israel: '\u{1F1EE}\u{1F1F1}',
};

const regionTitles: Record<string, string> = {
  china: 'China', korea: 'South Korea', japan: 'Japan', usa: 'USA', uk: 'UK',
  france: 'France', india: 'India', canada: 'Canada', singapore: 'Singapore',
  uae: 'UAE', switzerland: 'Switzerland', israel: 'Israel',
};

const regionCounts = new Map<string, number>();
const typeCounts = new Map<string, number>();
labs.forEach((l) => {
  regionCounts.set(l.region, (regionCounts.get(l.region) ?? 0) + 1);
  const t = l.type ?? 'other';
  typeCounts.set(t, (typeCounts.get(t) ?? 0) + 1);
});

const regionOptions = [...regionCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([slug, count]) => ({
    slug,
    label: regionTitles[slug] ?? slug,
    flag: regionFlags[slug] ?? '',
    count,
  }));

const typeOptions = [...typeCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([slug, count]) => ({ slug, label: slug, count }));

const ipoCounts = { public: 0, private: 0 };
labs.forEach(l => { l.ipo ? ipoCounts.public++ : ipoCounts.private++; });

const dimensions: FilterDimension[] = [
  { key: 'region', label: 'Region', kind: 'multi', rowAttr: 'region', options: regionOptions },
  { key: 'type', label: 'Type', kind: 'multi', rowAttr: 'type', options: typeOptions },
  { key: 'founded', label: 'Founded', kind: 'range', rowAttr: 'founded', excludeMissing: true,
    format: (n) => String(n) },
  { key: 'ipo', label: 'IPO', kind: 'single', rowAttr: 'ipoStatus',
    options: [
      { slug: 'public', label: 'Public', count: ipoCounts.public },
      { slug: 'private', label: 'Private', count: ipoCounts.private },
    ] },
  { key: 'valuation', label: 'Valuation', kind: 'range', rowAttr: 'valuation', unit: '$B',
    excludeMissing: true, format: (n) => `$${n}B` },
  { key: 'scale', label: 'Scale', kind: 'range', rowAttr: 'largest', unit: 'B params',
    excludeMissing: true, format: (n) => `${n}B` },
  { key: 'intelligence', label: 'Intelligence', kind: 'range', rowAttr: 'intelligence',
    excludeMissing: true, format: (n) => String(n) },
  { key: 'outputs', label: 'Outputs', kind: 'range', rowAttr: 'outputs',
    format: (n) => String(n) },
];
---

<Layout title="Labs">
  <header class="page-header">
    <h1>Lab Index</h1>
    <p class="subtitle">{labs.length} labs, {totalOutputs} outputs &middot; <button class="shortcut-hint" id="shortcut-hint">Keyboard shortcuts <kbd>?</kbd></button></p>
  </header>

  <FilterBar mode="palette" dimensions={dimensions} hotkey="f" id="filter-bar" />

  <table class="lab-table" id="lab-table">
    <thead>
      <tr>
        <th class="col-rank">#</th>
        <th class="col-name sortable" data-sort="name">Lab</th>
        <th class="col-region sortable" data-sort="region">Region</th>
        <th class="col-type sortable" data-sort="type">Type</th>
        <th class="col-founded sortable" data-sort="founded">Founded</th>
        <th class="col-ipo sortable" data-sort="ipo">IPO</th>
        <th class="col-valuation sortable" data-sort="valuation">Valuation</th>
        <th class="col-largest sortable" data-sort="largest">Scale</th>
        <th class="col-intelligence sortable" data-sort="intelligence">Intelligence</th>
        <th class="col-outputs sortable" data-sort="outputs">Outputs</th>
      </tr>
    </thead>
    <tbody>
      {labs.map((lab, i) => {
        const count = getOutputCount(lab.slug);
        const founded = lab.founded?.slice(0, 4) ?? '—';
        const valAmount = lab.valuation?.amount ?? '—';
        const valNum = (() => {
          const s = lab.valuation?.amount;
          if (!s) return 0;
          const n = parseFloat(s.replace(/[$,]/g, ''));
          if (s.endsWith('T')) return n * 1000;
          if (s.endsWith('M')) return n / 1000;
          return n;
        })();
        const largest = getLargestModel(lab.slug);
        const intel = getTopIntelligence(lab.slug);
        const ipoStatus = lab.ipo ? 'public' : 'private';
        return (
          <tr class="lab-row" data-href={`/labs/${lab.slug}`} data-index={i}
              data-name={lab.name} data-region={lab.region} data-type={lab.type ?? 'other'}
              data-founded={founded} data-ipo={lab.ipo?.year ?? 0} data-ipo-status={ipoStatus}
              data-valuation={valNum}
              data-largest={largest?.paramsB ?? 0} data-intelligence={intel?.score ?? 0} data-outputs={count}>
            <td class="col-rank"></td>
            <td class="col-name">
              <span class="lab-name-inner">
                <img
                  src={`/logos/${lab.slug}.png`}
                  alt=""
                  class="lab-logo"
                  width="20"
                  height="20"
                  loading="lazy"
                />
                <span class="lab-name">{lab.name}</span>
              </span>
            </td>
            <td class="col-region">{regionFlags[lab.region] ?? lab.region}</td>
            <td class="col-type"><TypeBadge type={lab.type ?? 'other'} /></td>
            <td class="col-founded">{founded}</td>
            <td class="col-ipo">{lab.ipo?.year ?? '—'}</td>
            <td class="col-valuation">{valAmount}</td>
            <td class="col-largest">
              {largest ? (
                <a href={`/outputs/${largest.labSlug}/${largest.slug}`} class="col-link" onclick="event.stopPropagation()">
                  {largest.estimated && (
                    <span
                      class="param-est-marker"
                      title={`Estimated value, not vendor-disclosed.\nSource: ${largest.estimate?.source_label ?? largest.estimate?.source ?? 'unknown'}${largest.estimate?.method ? `\nMethod: ${largest.estimate.method}` : ''}`}
                      onclick="event.preventDefault(); event.stopPropagation(); if (this.dataset.url) window.open(this.dataset.url, '_blank', 'noopener');"
                      data-url={largest.estimate?.source}
                    >~</span>
                  )}{largest.params}
                </a>
              ) : '—'}
            </td>
            <td class="col-intelligence">
              {intel ? (
                <a href={`/outputs/${intel.labSlug}/${intel.slug}`} class="col-link" onclick="event.stopPropagation()">
                  {intel.score}
                </a>
              ) : '—'}
            </td>
            <td class="col-outputs">{count}</td>
          </tr>
        );
      })}
    </tbody>
  </table>

  <div class="shortcut-modal hidden" id="shortcut-modal">
    <div class="shortcut-backdrop" id="shortcut-backdrop"></div>
    <div class="shortcut-dialog">
      <h3>Keyboard shortcuts</h3>
      <div class="shortcut-grid">
        <div class="shortcut-group">
          <h4>Navigation</h4>
          <dl>
            <div><dt><kbd>j</kbd></dt><dd>Move down</dd></div>
            <div><dt><kbd>k</kbd></dt><dd>Move up</dd></div>
            <div><dt><kbd>o</kbd> / <kbd>Enter</kbd></dt><dd>Open lab</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>g</kbd></dt><dd>Go to top</dd></div>
            <div><dt><kbd>G</kbd></dt><dd>Go to bottom</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>h</kbd></dt><dd>Go home</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>t</kbd></dt><dd>Go to timeline</dd></div>
          </dl>
        </div>
        <div class="shortcut-group">
          <h4>Other</h4>
          <dl>
            <div><dt><kbd>/</kbd></dt><dd>Search</dd></div>
            <div><dt><kbd>f</kbd></dt><dd>Filter</dd></div>
            <div><dt><kbd>Esc</kbd></dt><dd>Clear / close</dd></div>
            <div><dt><kbd>?</kbd></dt><dd>Show this help</dd></div>
          </dl>
        </div>
      </div>
      <button class="close-btn" id="close-shortcuts">&times;</button>
    </div>
  </div>
</Layout>

<script>
  import type { FilterChangeDetail, FilterDimension } from '../lib/filters/types';
  import { rowMatches } from '../lib/filters/state';

  const allRows = Array.from(document.querySelectorAll<HTMLTableRowElement>('.lab-row'));
  const modal = document.getElementById('shortcut-modal')!;
  const backdrop = document.getElementById('shortcut-backdrop')!;
  const closeBtn = document.getElementById('close-shortcuts')!;
  const hintBtn = document.getElementById('shortcut-hint')!;
  const tbody = document.querySelector('.lab-table tbody')!;
  const headers = document.querySelectorAll<HTMLTableCellElement>('th.sortable');
  const filterBarEl = document.getElementById('filter-bar')!;
  const filterCountEl = filterBarEl.querySelector<HTMLElement>('.filter-count')!;

  const dimensions: FilterDimension[] = JSON.parse(
    document.getElementById('filter-bar-config')!.textContent!,
  ).dimensions;

  let visibleRows: HTMLTableRowElement[] = [...allRows];
  let selected = -1;
  let waitingForG = false;
  let gTimer: ReturnType<typeof setTimeout> | null = null;
  let lastFilterState: Parameters<typeof rowMatches>[1] = {};

  // ─── Visibility (driven by FilterBar via filters:changed) ─────────────

  filterBarEl.addEventListener('filters:changed', (e) => {
    lastFilterState = (e as CustomEvent<FilterChangeDetail>).detail.state;
    applyFilters();
  });

  function applyFilters() {
    allRows.forEach(row => {
      const ok = rowMatches(row.dataset as Record<string, string | undefined>, lastFilterState, dimensions);
      row.style.display = ok ? '' : 'none';
    });
    visibleRows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('.lab-row'))
      .filter(r => r.style.display !== 'none');
    rerankVisibleRows();
    filterCountEl.textContent = visibleRows.length < allRows.length
      ? `${visibleRows.length} of ${allRows.length} labs`
      : '';
    // Clamp / refresh selection.
    allRows.forEach(r => r.classList.remove('selected'));
    if (selected >= visibleRows.length) selected = visibleRows.length - 1;
    if (selected >= 0 && visibleRows[selected]) visibleRows[selected]!.classList.add('selected');
    else selected = -1;
  }

  function rerankVisibleRows() {
    let rank = 1;
    for (const child of Array.from(tbody.children)) {
      const row = child as HTMLTableRowElement;
      const cell = row.querySelector('.col-rank');
      if (!cell) continue;
      cell.textContent = row.style.display === 'none' ? '' : String(rank++);
    }
  }

  // ─── Selection / navigation ──────────────────────────────────────────

  function select(index: number) {
    if (visibleRows.length === 0) return;
    const clamped = Math.max(0, Math.min(index, visibleRows.length - 1));
    allRows.forEach(r => r.classList.remove('selected'));
    selected = clamped;
    visibleRows[selected]!.classList.add('selected');
    visibleRows[selected]!.scrollIntoView({ block: 'nearest' });
  }

  function openSelected() {
    if (selected >= 0 && selected < visibleRows.length) {
      const href = visibleRows[selected]!.dataset.href;
      if (href) window.location.href = href;
    }
  }

  function toggleModal(show?: boolean) {
    const isShown = !modal.classList.contains('hidden');
    const shouldShow = show ?? !isShown;
    modal.classList.toggle('hidden', !shouldShow);
  }

  // Click rows to navigate.
  allRows.forEach(row => {
    row.addEventListener('click', () => {
      const href = row.dataset.href;
      if (href) window.location.href = href;
    });
  });

  // ─── Page-level keyboard shortcuts ───────────────────────────────────

  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if ((window as any).isSearchOpen) return;
    if (e.ctrlKey || e.metaKey || e.altKey) return;

    // FilterBar handles its own keys when its panel is open; let it run.
    const target = e.target as HTMLElement | null;
    if (target?.closest('.dim-panel') || target?.closest('.palette-panel')) return;

    switch (e.key) {
      case 'j':
        e.preventDefault();
        select(selected + 1);
        break;
      case 'k':
        e.preventDefault();
        select(selected - 1);
        break;
      case 'o':
      case 'Enter':
        e.preventDefault();
        openSelected();
        break;
      case 'g':
        if (waitingForG) {
          e.preventDefault();
          select(0);
          waitingForG = false;
          if (gTimer) clearTimeout(gTimer);
        } else {
          waitingForG = true;
          gTimer = setTimeout(() => { waitingForG = false; }, 500);
        }
        break;
      case 'G':
        e.preventDefault();
        select(visibleRows.length - 1);
        break;
      case '?':
        e.preventDefault();
        toggleModal();
        break;
      case 'Escape':
        if (!modal.classList.contains('hidden')) {
          e.preventDefault();
          toggleModal(false);
        } else {
          // Don't preventDefault — let FilterBar's own Esc-handlers run too.
          allRows.forEach(r => r.classList.remove('selected'));
          selected = -1;
        }
        break;
    }
  });

  backdrop.addEventListener('click', () => toggleModal(false));
  closeBtn.addEventListener('click', () => toggleModal(false));
  hintBtn.addEventListener('click', () => toggleModal(true));

  // ─── Sort ────────────────────────────────────────────────────────────

  let currentSort = '';
  let sortAsc = true;

  function parseVal(v: string): number {
    return parseFloat(v) || 0;
  }

  function sortTable(key: string) {
    if (currentSort === key) {
      sortAsc = !sortAsc;
    } else {
      currentSort = key;
      sortAsc = key === 'name' || key === 'type' || key === 'region';
    }

    headers.forEach(h => {
      h.classList.remove('sort-asc', 'sort-desc');
      if (h.dataset.sort === key) {
        h.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
      }
    });

    const sorted = [...allRows].sort((a, b) => {
      const av = a.dataset[key] ?? '';
      const bv = b.dataset[key] ?? '';
      if (key === 'founded' || key === 'ipo' || key === 'valuation' || key === 'largest' || key === 'intelligence' || key === 'outputs') {
        const diff = parseVal(av) - parseVal(bv);
        return sortAsc ? diff : -diff;
      }
      const cmp = av.localeCompare(bv);
      return sortAsc ? cmp : -cmp;
    });

    sorted.forEach((row) => tbody.appendChild(row));
    rerankVisibleRows();
    selected = -1;
    allRows.forEach(r => r.classList.remove('selected'));
  }

  headers.forEach(th => {
    th.addEventListener('click', () => sortTable(th.dataset.sort!));
  });

  // ─── Boot ────────────────────────────────────────────────────────────
  // FilterBar fires its initial filters:changed event right after init,
  // which calls applyFilters(). We just need to set the initial sort.
  sortTable('intelligence'); // default: intelligence desc
  modal.classList.add('hidden');
</script>

<style>
  .page-header {
    margin-bottom: 1.25rem;
  }

  .page-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .shortcut-hint {
    all: unset;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .shortcut-hint:hover {
    color: var(--text);
  }

  .shortcut-hint kbd {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0 0.3em;
    font-size: 0.75rem;
    font-family: inherit;
    margin-left: 0.15em;
  }

  /* Table */
  .lab-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .lab-table thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .lab-table th {
    text-align: left;
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    background: var(--bg);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
    user-select: none;
  }

  th.sortable {
    cursor: pointer;
  }

  th.sortable:hover {
    color: var(--text);
  }

  th.sortable::after {
    content: '';
    display: inline-block;
    width: 0.6em;
    margin-left: 0.3em;
  }

  th.sort-asc::after {
    content: '\25B2';
  }

  th.sort-desc::after {
    content: '\25BC';
  }

  .lab-row {
    cursor: pointer;
    transition: background 0.08s;
  }

  .lab-row td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .lab-row:hover {
    background: rgba(37, 99, 235, 0.04);
  }

  .lab-row.selected {
    background: rgba(37, 99, 235, 0.08);
    outline: 2px solid rgba(37, 99, 235, 0.3);
    outline-offset: -2px;
  }

  .lab-row:last-child td {
    border-bottom: none;
  }

  /* Columns */
  .col-rank,
  th.col-rank {
    text-align: right;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    font-size: 0.75rem;
    padding-right: 0.25rem;
    white-space: nowrap;
    width: 1%;
  }

  .col-name {
    font-weight: 600;
    white-space: nowrap;
  }

  .lab-name-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .lab-logo {
    border-radius: 4px;
    flex-shrink: 0;
    background: var(--surface);
  }

  .col-region {
    text-align: center;
    font-size: 1.1rem;
  }

  th.col-region {
    text-align: center;
  }

  .col-type {
    white-space: nowrap;
  }

  .col-founded,
  .col-ipo,
  .col-valuation,
  .col-largest,
  .col-intelligence,
  .col-outputs {
    text-align: right;
    white-space: nowrap;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  th.col-founded,
  th.col-ipo,
  th.col-valuation,
  th.col-largest,
  th.col-intelligence,
  th.col-outputs {
    text-align: right;
  }

  .col-link {
    color: var(--text-muted);
    text-decoration: none;
  }

  .col-link:hover {
    color: var(--text);
    text-decoration: underline;
  }

  .param-est-marker {
    color: #d97706;
    font-weight: 600;
    margin-right: 0.05em;
    cursor: help;
    border-bottom: 1px dotted currentColor;
    line-height: 1;
  }

  .param-est-marker:hover {
    color: #b45309;
  }

  /* Shortcuts modal */
  .shortcut-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shortcut-modal.hidden {
    display: none;
  }

  .shortcut-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
  }

  .shortcut-dialog {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem 2rem;
    max-width: 480px;
    width: 90%;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .shortcut-dialog h3 {
    font-size: 1.125rem;
    margin-bottom: 1.25rem;
  }

  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .shortcut-group h4 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .shortcut-group dl {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .shortcut-group dl > div {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .shortcut-group dt {
    flex-shrink: 0;
  }

  .shortcut-group dd {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: right;
  }

  .shortcut-group kbd {
    display: inline-block;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15em 0.45em;
    font-size: 0.8rem;
    font-family: inherit;
    min-width: 1.6em;
    text-align: center;
    box-shadow: 0 1px 0 var(--border);
  }

  .close-btn {
    all: unset;
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-size: 1.25rem;
    cursor: pointer;
    color: var(--text-muted);
    line-height: 1;
  }

  .close-btn:hover {
    color: var(--text);
  }
</style>
