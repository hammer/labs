---
import Layout from '../components/Layout.astro';
import TypeBadge from '../components/TypeBadge.astro';
import { getAllLabs, getOutputCount, getAllOutputsChronological, getLargestModel } from '../data/loader.js';

const labs = getAllLabs().sort((a, b) => getOutputCount(b.slug) - getOutputCount(a.slug));
const totalOutputs = getAllOutputsChronological().length;
---

<Layout title="Labs">
  <header class="page-header">
    <h1>AI Lab Tracker</h1>
    <p class="subtitle">{labs.length} labs, {totalOutputs} outputs &middot; <button class="shortcut-hint" id="shortcut-hint">Keyboard shortcuts <kbd>?</kbd></button></p>
  </header>

  <table class="lab-table" id="lab-table">
    <thead>
      <tr>
        <th class="col-name sortable" data-sort="name">Lab</th>
        <th class="col-type sortable" data-sort="type">Type</th>
        <th class="col-founded sortable" data-sort="founded">Founded</th>
        <th class="col-ipo sortable" data-sort="ipo">IPO</th>
        <th class="col-valuation sortable" data-sort="valuation">Valuation</th>
        <th class="col-largest sortable" data-sort="largest">Largest Model</th>
        <th class="col-outputs sortable" data-sort="outputs">Outputs</th>
      </tr>
    </thead>
    <tbody>
      {labs.map((lab, i) => {
        const count = getOutputCount(lab.slug);
        const founded = lab.founded?.slice(0, 4) ?? '—';
        const valAmount = lab.valuation?.amount ?? '—';
        const valNum = lab.valuation?.amount
          ? parseFloat(lab.valuation.amount.replace(/[$,]/g, '').replace(/T$/, '000').replace(/B$/, '').replace(/M$/, '0.001'))
          : 0;
        const largest = getLargestModel(lab.slug);
        return (
          <tr class="lab-row" data-href={`/labs/${lab.slug}`} data-index={i}
              data-name={lab.name} data-type={lab.type ?? 'other'}
              data-founded={founded} data-ipo={lab.ipo?.year ?? 0} data-valuation={valNum}
              data-largest={largest?.paramsB ?? 0} data-outputs={count}>
            <td class="col-name">
              <img
                src={`/logos/${lab.slug}.png`}
                alt=""
                class="lab-logo"
                width="20"
                height="20"
                loading="lazy"
              />
              <span class="lab-name">{lab.name}</span>
            </td>
            <td class="col-type"><TypeBadge type={lab.type ?? 'other'} /></td>
            <td class="col-founded">{founded}</td>
            <td class="col-ipo">{lab.ipo?.year ?? '—'}</td>
            <td class="col-valuation">{valAmount}</td>
            <td class="col-largest">{largest?.params ?? '—'}</td>
            <td class="col-outputs">{count}</td>
          </tr>
        );
      })}
    </tbody>
  </table>

  <div class="shortcut-modal" id="shortcut-modal">
    <div class="shortcut-backdrop" id="shortcut-backdrop"></div>
    <div class="shortcut-dialog">
      <h3>Keyboard shortcuts</h3>
      <div class="shortcut-grid">
        <div class="shortcut-group">
          <h4>Navigation</h4>
          <dl>
            <div><dt><kbd>j</kbd></dt><dd>Move down</dd></div>
            <div><dt><kbd>k</kbd></dt><dd>Move up</dd></div>
            <div><dt><kbd>o</kbd> / <kbd>Enter</kbd></dt><dd>Open lab</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>g</kbd></dt><dd>Go to top</dd></div>
            <div><dt><kbd>G</kbd></dt><dd>Go to bottom</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>h</kbd></dt><dd>Go home</dd></div>
            <div><dt><kbd>g</kbd> then <kbd>t</kbd></dt><dd>Go to timeline</dd></div>
          </dl>
        </div>
        <div class="shortcut-group">
          <h4>Other</h4>
          <dl>
            <div><dt><kbd>/</kbd></dt><dd>Search</dd></div>
            <div><dt><kbd>Esc</kbd></dt><dd>Clear / close</dd></div>
            <div><dt><kbd>?</kbd></dt><dd>Show this help</dd></div>
          </dl>
        </div>
      </div>
      <button class="close-btn" id="close-shortcuts">&times;</button>
    </div>
  </div>
</Layout>

<script>
  const rows = Array.from(document.querySelectorAll<HTMLTableRowElement>('.lab-row'));
  const modal = document.getElementById('shortcut-modal')!;
  const backdrop = document.getElementById('shortcut-backdrop')!;
  const closeBtn = document.getElementById('close-shortcuts')!;
  const hintBtn = document.getElementById('shortcut-hint')!;

  let selected = -1;
  let waitingForG = false;
  let gTimer: ReturnType<typeof setTimeout> | null = null;

  function select(index: number) {
    const clamped = Math.max(0, Math.min(index, rows.length - 1));
    rows.forEach(r => r.classList.remove('selected'));
    selected = clamped;
    rows[selected].classList.add('selected');
    rows[selected].scrollIntoView({ block: 'nearest' });
  }

  function openSelected() {
    if (selected >= 0 && selected < rows.length) {
      const href = rows[selected].dataset.href;
      if (href) window.location.href = href;
    }
  }

  function toggleModal(show?: boolean) {
    const isShown = !modal.classList.contains('hidden');
    const shouldShow = show ?? !isShown;
    modal.classList.toggle('hidden', !shouldShow);
  }

  // Click to navigate
  rows.forEach(row => {
    row.addEventListener('click', () => {
      const href = row.dataset.href;
      if (href) window.location.href = href;
    });
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    // Ignore when typing in input or if search is open
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if ((window as any).isSearchOpen) return;

    // Don't trigger shortcuts with modifier keys
    if (e.ctrlKey || e.metaKey || e.altKey) return;

    switch (e.key) {
      case 'j':
        e.preventDefault();
        select(selected + 1);
        break;
      case 'k':
        e.preventDefault();
        select(selected - 1);
        break;
      case 'o':
      case 'Enter':
        e.preventDefault();
        openSelected();
        break;
      case 'g':
        if (waitingForG) {
          e.preventDefault();
          select(0);
          waitingForG = false;
          if (gTimer) clearTimeout(gTimer);
        } else {
          waitingForG = true;
          gTimer = setTimeout(() => { waitingForG = false; }, 500);
        }
        break;
      case 'G':
        e.preventDefault();
        select(rows.length - 1);
        break;
      case '?':
        e.preventDefault();
        toggleModal();
        break;
      case 'Escape':
        e.preventDefault();
        if (!modal.classList.contains('hidden')) {
          toggleModal(false);
        } else {
          rows.forEach(r => r.classList.remove('selected'));
          selected = -1;
        }
        break;
    }
  });

  backdrop.addEventListener('click', () => toggleModal(false));
  closeBtn.addEventListener('click', () => toggleModal(false));
  hintBtn.addEventListener('click', () => toggleModal(true));

  // Column sorting
  const headers = document.querySelectorAll<HTMLTableCellElement>('th.sortable');
  const tbody = document.querySelector('.lab-table tbody')!;
  let currentSort = '';
  let sortAsc = true;

  function parseVal(v: string): number {
    return parseFloat(v) || 0;
  }

  function sortTable(key: string) {
    if (currentSort === key) {
      sortAsc = !sortAsc;
    } else {
      currentSort = key;
      sortAsc = key === 'name' || key === 'type';
    }

    headers.forEach(h => {
      h.classList.remove('sort-asc', 'sort-desc');
      if (h.dataset.sort === key) {
        h.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
      }
    });

    const sorted = [...rows].sort((a, b) => {
      const av = a.dataset[key] ?? '';
      const bv = b.dataset[key] ?? '';
      if (key === 'founded' || key === 'ipo' || key === 'valuation' || key === 'largest' || key === 'outputs') {
        const diff = parseVal(av) - parseVal(bv);
        return sortAsc ? diff : -diff;
      }
      const cmp = av.localeCompare(bv);
      return sortAsc ? cmp : -cmp;
    });

    sorted.forEach(row => tbody.appendChild(row));
    visibleRows = rows.filter(r => (r as HTMLElement).style.display !== 'none');
    selected = -1;
  }

  headers.forEach(th => {
    th.addEventListener('click', () => {
      sortTable(th.dataset.sort!);
    });
  });

  // Start with modal hidden
  modal.classList.add('hidden');
</script>

<style>
  .page-header {
    margin-bottom: 1.25rem;
  }

  .page-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .shortcut-hint {
    all: unset;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .shortcut-hint:hover {
    color: var(--text);
  }

  .shortcut-hint kbd {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0 0.3em;
    font-size: 0.75rem;
    font-family: inherit;
    margin-left: 0.15em;
  }

  /* Table */
  .lab-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .lab-table thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .lab-table th {
    text-align: left;
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    background: var(--bg);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
    user-select: none;
  }

  th.sortable {
    cursor: pointer;
  }

  th.sortable:hover {
    color: var(--text);
  }

  th.sortable::after {
    content: '';
    display: inline-block;
    width: 0.6em;
    margin-left: 0.3em;
  }

  th.sort-asc::after {
    content: '\25B2';
  }

  th.sort-desc::after {
    content: '\25BC';
  }

  .lab-row {
    cursor: pointer;
    transition: background 0.08s;
  }

  .lab-row td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .lab-row:hover {
    background: rgba(37, 99, 235, 0.04);
  }

  .lab-row.selected {
    background: rgba(37, 99, 235, 0.08);
    outline: 2px solid rgba(37, 99, 235, 0.3);
    outline-offset: -2px;
  }

  .lab-row:last-child td {
    border-bottom: none;
  }

  /* Columns */
  .col-name {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .lab-logo {
    border-radius: 4px;
    flex-shrink: 0;
    background: var(--surface);
  }

  .col-type {
    white-space: nowrap;
  }

  .col-founded,
  .col-ipo,
  .col-valuation,
  .col-largest,
  .col-outputs {
    text-align: right;
    white-space: nowrap;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  th.col-founded,
  th.col-ipo,
  th.col-valuation,
  th.col-largest,
  th.col-outputs {
    text-align: right;
  }

  /* Search bar */
  .search-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: none;
    justify-content: center;
    padding: 1rem;
    background: rgba(0,0,0,0.15);
  }

  .search-bar.active {
    display: flex;
  }

  .search-bar input {
    width: 100%;
    max-width: 480px;
    padding: 0.6rem 1rem;
    font-size: 1rem;
    border: 2px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text);
    outline: none;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  }

  .search-bar input:focus {
    border-color: #2563eb;
  }

  /* Shortcuts modal */
  .shortcut-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shortcut-modal.hidden {
    display: none;
  }

  .shortcut-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
  }

  .shortcut-dialog {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem 2rem;
    max-width: 480px;
    width: 90%;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .shortcut-dialog h3 {
    font-size: 1.125rem;
    margin-bottom: 1.25rem;
  }

  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .shortcut-group h4 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .shortcut-group dl {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .shortcut-group dl > div {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .shortcut-group dt {
    flex-shrink: 0;
  }

  .shortcut-group dd {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: right;
  }

  .shortcut-group kbd {
    display: inline-block;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15em 0.45em;
    font-size: 0.8rem;
    font-family: inherit;
    min-width: 1.6em;
    text-align: center;
    box-shadow: 0 1px 0 var(--border);
  }

  .close-btn {
    all: unset;
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-size: 1.25rem;
    cursor: pointer;
    color: var(--text-muted);
    line-height: 1;
  }

  .close-btn:hover {
    color: var(--text);
  }
</style>
