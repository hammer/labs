---
import Layout from '../components/Layout.astro';
import LabCard from '../components/LabCard.astro';
import { getLabsGroupedByType, getOutputCount, getAllLabs, getAllOutputsChronological } from '../data/loader.js';

const grouped = getLabsGroupedByType();
const totalLabs = getAllLabs().length;
const totalOutputs = getAllOutputsChronological().length;
const typeOrder = ['corporate', 'startup', 'nonprofit', 'academic', 'other'];
const typeLabels: Record<string, string> = {
  corporate: 'Corporate',
  startup: 'Startup',
  nonprofit: 'Nonprofit',
  academic: 'Academic',
  other: 'Other',
};
---

<Layout title="Labs">
  <header class="page-header">
    <h1>AI Lab Tracker</h1>
    <p class="subtitle">{totalLabs} labs, {totalOutputs} outputs</p>
  </header>

  {typeOrder.map((type) => {
    const labs = grouped[type];
    if (!labs?.length) return null;
    return (
      <section class="type-section">
        <h2 class="type-heading">
          <span class="type-label" style={`--type-color: var(--color-${type})`}>
            {typeLabels[type] ?? type}
          </span>
          <span class="type-count">{labs.length}</span>
        </h2>
        <div class="lab-grid">
          {labs.map((lab) => (
            <LabCard lab={lab} outputCount={getOutputCount(lab.slug)} />
          ))}
        </div>
      </section>
    );
  })}
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .type-section {
    margin-bottom: 2rem;
  }

  .type-heading {
    font-size: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .type-label {
    color: var(--type-color);
  }

  .type-count {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .lab-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }
</style>
