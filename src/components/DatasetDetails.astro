---
import type { Output, MetricsEntry } from '../schema.js';

interface Props {
  dataset: NonNullable<Output['dataset']>;
  metrics?: MetricsEntry;
}

const { dataset, metrics } = Astro.props;
---

<div class="dataset-details">
  <div class="specs">
    {dataset.size && (
      <div class="spec">
        <span class="spec-label">Size</span>
        <span class="spec-value">{dataset.size}</span>
      </div>
    )}
    {dataset.format && (
      <div class="spec">
        <span class="spec-label">Format</span>
        <span class="spec-value">{dataset.format}</span>
      </div>
    )}
    {dataset.license && (
      <div class="spec">
        <span class="spec-label">License</span>
        <span class="spec-value">{dataset.license}</span>
      </div>
    )}
    {metrics?.hf_downloads && (
      <div class="spec">
        <span class="spec-label">Downloads</span>
        <span class="spec-value">{metrics.hf_downloads.toLocaleString()}</span>
      </div>
    )}
  </div>

  {dataset.languages && dataset.languages.length > 0 && (
    <div class="languages">
      <span class="lang-label">Languages:</span>
      {dataset.languages.join(', ')}
    </div>
  )}

  {(dataset.github || dataset.huggingface_url || dataset.url) && (
    <div class="dataset-links">
      {dataset.github && <a href={dataset.github} class="dataset-link" target="_blank" rel="noopener">GitHub</a>}
      {dataset.huggingface_url && <a href={dataset.huggingface_url} class="dataset-link" target="_blank" rel="noopener">HuggingFace</a>}
      {dataset.url && <a href={dataset.url} class="dataset-link" target="_blank" rel="noopener">Website</a>}
    </div>
  )}
</div>

<style>
  .dataset-details {
    margin-top: 0.5rem;
  }

  .specs {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .spec {
    background: var(--bg);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
  }

  .spec-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .spec-value {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .languages {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .lang-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-right: 0.4rem;
  }

  .dataset-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .dataset-link {
    display: inline-block;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.15s;
  }

  .dataset-link:hover {
    border-color: var(--color-dataset);
    color: var(--color-dataset);
  }
</style>
