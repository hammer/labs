<div id="search-dropdown" class="search-dropdown hidden">
  <div class="search-input-container">
    <input
      type="text"
      id="global-search-input"
      placeholder="Search labs and outputs..."
      autocomplete="off"
    />
  </div>
  <div id="search-results" class="search-results"></div>
  <div class="search-footer">
    <span class="search-shortcut"><strong>&uarr;&darr;</strong> to navigate</span>
    <span class="search-shortcut"><strong>&crarr;</strong> to open</span>
    <span class="search-shortcut"><strong>Esc</strong> to close</span>
  </div>
</div>

<script>
  interface SearchItem {
    type: 'lab' | 'output' | 'person';
    name: string;
    slug: string;
    url: string;
    sub: string;
    date?: string;
    arxiv?: string;
    role?: string;
  }

  const dropdown = document.getElementById('search-dropdown')!;
  const input = document.getElementById('global-search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results')!;

  let searchData: SearchItem[] = [];
  let filteredData: SearchItem[] = [];
  let selectedIndex = -1;
  let isLoaded = false;

  async function loadData() {
    if (isLoaded) return;
    try {
      const resp = await fetch('/search-data.json');
      searchData = await resp.json();
      isLoaded = true;
    } catch (e) {
      console.error('Failed to load search data', e);
    }
  }

  function toggleSearch(show?: boolean) {
    const isShown = !dropdown.classList.contains('hidden');
    const shouldShow = show ?? !isShown;

    if (shouldShow) {
      dropdown.classList.remove('hidden');
      (window as any).isSearchOpen = true;
      loadData();
      input.focus();
      input.value = '';
      renderResults();
    } else {
      dropdown.classList.add('hidden');
      (window as any).isSearchOpen = false;
      input.blur();
    }
  }

  function renderResults() {
    const query = input.value.toLowerCase().trim();
    if (!query) {
      resultsContainer.innerHTML = '<div class="search-empty">Type to search...</div>';
      filteredData = [];
      selectedIndex = -1;
      return;
    }

    filteredData = searchData.filter(item =>
      item.name.toLowerCase().includes(query) ||
      item.slug.toLowerCase().includes(query) ||
      item.sub.toLowerCase().includes(query) ||
      (item.arxiv && item.arxiv.toLowerCase().includes(query))
    ).slice(0, 15);

    if (filteredData.length === 0) {
      resultsContainer.innerHTML = '<div class="search-empty">No results found</div>';
      selectedIndex = -1;
      return;
    }

    resultsContainer.innerHTML = filteredData.map((item, i) => {
      const arxivDisplay = item.arxiv ? item.arxiv.split(' ').map(id => `arXiv:${id}`).join(', ') : '';
      
      return `
        <div class="search-item ${i === selectedIndex ? 'selected' : ''}" data-index="${i}" data-url="${item.url}">
          <div class="search-item-info">
            <div class="search-item-name">${item.name}</div>
            <div class="search-item-meta">
              <span class="search-item-type" data-type="${item.type}">${item.type}</span>
              <span class="search-item-sep">&middot;</span>
              <span class="search-item-sub">${item.sub}</span>
              ${item.role ? `<span class="search-item-sep">&middot;</span><span class="search-item-role">${item.role}</span>` : ''}
              ${arxivDisplay ? `<span class="search-item-sep">&middot;</span><span class="search-item-arxiv">${arxivDisplay}</span>` : ''}
              ${item.date ? `<span class="search-item-sep">&middot;</span><span class="search-item-date">${item.date}</span>` : ''}
            </div>
          </div>
        </div>
      `;
    }).join('');

    if (selectedIndex >= filteredData.length) {
      selectedIndex = filteredData.length - 1;
    } else if (selectedIndex === -1 && filteredData.length > 0) {
      selectedIndex = 0;
      renderResults();
    }
  }

  function selectIndex(index: number) {
    if (filteredData.length === 0) return;
    
    // Remove previous selection
    const items = resultsContainer.querySelectorAll('.search-item');
    if (selectedIndex >= 0 && selectedIndex < items.length) {
      items[selectedIndex].classList.remove('selected');
    }

    selectedIndex = Math.max(0, Math.min(index, filteredData.length - 1));
    
    // Add new selection
    const selected = items[selectedIndex];
    if (selected) {
      selected.classList.add('selected');
      selected.scrollIntoView({ block: 'nearest' });
    }
  }

  function openSelected() {
    if (selectedIndex >= 0 && selectedIndex < filteredData.length) {
      window.location.href = filteredData[selectedIndex].url;
    }
  }

  // Input events
  input.addEventListener('input', () => {
    selectedIndex = 0;
    renderResults();
  });

  input.addEventListener('keydown', (e) => {
    switch (e.key) {
      case 'ArrowDown':
        e.preventDefault();
        selectIndex(selectedIndex + 1);
        break;
      case 'ArrowUp':
        e.preventDefault();
        selectIndex(selectedIndex - 1);
        break;
      case 'Enter':
        e.preventDefault();
        openSelected();
        break;
      case 'Escape':
        e.preventDefault();
        toggleSearch(false);
        break;
    }
  });

  // Global shortcut
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.ctrlKey || e.metaKey || e.altKey) return;

    if (e.key === '/') {
      e.preventDefault();
      toggleSearch(true);
    }
  });

  // Click outside to close
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!dropdown.contains(target) && !target.closest('#nav-search-btn')) {
      toggleSearch(false);
    }
  });

  // Click on result
  resultsContainer.addEventListener('click', (e) => {
    const item = (e.target as HTMLElement).closest('.search-item');
    if (item) {
      window.location.href = (item as HTMLElement).dataset.url!;
    }
  });

  window.addEventListener('open-global-search', () => toggleSearch(true));
</script>

<style is:global>
  .search-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    z-index: 1000;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    width: 450px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    animation: dropdown-slide-down 0.15s ease-out;
  }

  @keyframes dropdown-slide-down {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .search-dropdown.hidden {
    display: none;
  }

  .search-input-container {
    padding: 0.75rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .search-input-container input {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.9rem;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    outline: none;
  }

  .search-input-container input:focus {
    border-color: #2563eb;
  }

  .search-results {
    max-height: 320px;
    overflow-y: auto;
    padding: 0.4rem;
  }

  .search-item {
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.1s;
    display: block;
    text-decoration: none !important;
    color: inherit;
  }

  .search-item:hover,
  .search-item.selected {
    background: rgba(37, 99, 235, 0.12) !important;
  }

  .search-item.selected {
    outline: 2px solid rgba(37, 99, 235, 0.5) !important;
    outline-offset: -1px;
  }

  .search-item-name {
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text);
  }

  .search-item-meta {
    font-size: 0.7rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .search-item-type {
    text-transform: uppercase;
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .search-item-type[data-type="lab"] { color: #2563eb; }
  .search-item-type[data-type="output"] { color: #7c3aed; }
  .search-item-type[data-type="person"] { color: #ea580c; }

  .search-empty {
    padding: 1.5rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .search-footer {
    padding: 0.5rem 0.75rem;
    background: var(--bg);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    color: var(--text-muted);
  }

  .search-shortcut strong {
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0 0.2rem;
    border-radius: 3px;
    font-family: monospace;
  }
</style>
