---
import type { Output } from '../schema.js';
import TypeBadge from './TypeBadge.astro';

interface Props {
  output: Output;
  showLab?: boolean;
  labSlug?: string;
}

const { output, showLab = false, labSlug } = Astro.props;
const labs = Array.isArray(output.lab) ? output.lab : [output.lab];
const linkSlug = labSlug ?? labs[0];
const excerpt = output.description
  ? output.description.length > 150
    ? output.description.slice(0, 150).trimEnd() + '…'
    : output.description
  : null;
---

<a href={`/outputs/${linkSlug}/${output.slug}`} class="card">
  <div class="card-header">
    <h3 class="card-title">{output.name}</h3>
    <TypeBadge type={output.type} />
  </div>
  <div class="card-meta">
    <time>{output.date}</time>
    {showLab && <span class="lab-name">{labs.join(', ')}</span>}
  </div>
  {excerpt && <p class="excerpt">{excerpt}</p>}
</a>

<style>
  .card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    color: var(--text);
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--text-muted);
    text-decoration: none;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .card-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.375rem;
  }

  .lab-name {
    font-weight: 500;
  }

  .excerpt {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
