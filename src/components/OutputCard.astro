---
import { isGrouped, getOutputTypes, type Output } from '../schema.js';
import type { MetricsEntry } from '../schema.js';
import { formatCompact } from '../utils.js';
import TypeBadge from './TypeBadge.astro';

interface Props {
  output: Output & { _metrics?: MetricsEntry };
  showLab?: boolean;
  labSlug?: string;
}

const { output, showLab = false, labSlug } = Astro.props;
const labs = Array.isArray(output.lab) ? output.lab : [output.lab];
const linkSlug = labSlug ?? (output as any)._labSlug ?? labs[0];
const excerpt = output.description
  ? output.description.length > 150
    ? output.description.slice(0, 150).trimEnd() + '…'
    : output.description
  : null;
const types = getOutputTypes(output);
const grouped = isGrouped(output);
const m = (output as any)._metrics as MetricsEntry | undefined;
const hasMetrics = m && (m.github_stars || m.hf_downloads || m.citations);
---

<a href={`/outputs/${linkSlug}/${output.slug}`} class="card">
  <div class="card-header">
    <h3 class="card-title">
      {output.name}
      {grouped && <span class="group-count">{output.outputs.length}</span>}
    </h3>
    <div class="type-badges">
      {types.map(t => <TypeBadge type={t} />)}
    </div>
  </div>
  <div class="card-meta">
    <time>{output.date}</time>
    {showLab && <span class="lab-name">{labs.join(', ')}</span>}
  </div>
  {excerpt && <p class="excerpt">{excerpt}</p>}
  {hasMetrics && (
    <div class="metrics-row">
      {m!.github_stars && <span class="metric-badge" title="GitHub stars">&#9733; {formatCompact(m!.github_stars)}</span>}
      {m!.hf_downloads && <span class="metric-badge" title="HuggingFace downloads">&#8595; {formatCompact(m!.hf_downloads)}</span>}
      {m!.citations && <span class="metric-badge" title="Citations">&#128196; {formatCompact(m!.citations)}</span>}
    </div>
  )}
</a>

<style>
  .card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    color: var(--text);
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--text-muted);
    text-decoration: none;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .group-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 600;
    min-width: 1.2em;
    padding: 0 0.35em;
    height: 1.2em;
    border-radius: 9999px;
    background: var(--border);
    color: var(--text-muted);
    margin-left: 0.3rem;
    vertical-align: middle;
  }

  .type-badges {
    display: flex;
    gap: 0.3rem;
    flex-shrink: 0;
  }

  .card-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.375rem;
  }

  .lab-name {
    font-weight: 500;
  }

  .excerpt {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .metrics-row {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .metric-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2em;
    font-size: 0.7rem;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15em 0.45em;
    font-variant-numeric: tabular-nums;
  }
</style>
